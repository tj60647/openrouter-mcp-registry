# OpenRouter API key (required for sync)
OPENROUTER_API_KEY=sk-or-...

# Vercel Postgres connection string (required)
POSTGRES_URL=postgres://...

# Admin secret for protected endpoints (required)
ADMIN_SECRET=your-secure-admin-secret

# Public URL of this app (used for MCP info page)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Cron secret - Vercel injects this automatically
CRON_SECRET=
