# OpenRouter API key (required for sync and the /demo chatbot)
OPENROUTER_API_KEY=sk-or-...

# OpenRouter model used by the /demo chatbot (optional, defaults to openai/gpt-4o-mini)
CHAT_MODEL=openai/gpt-4o-mini

# Vercel Postgres connection string (required)
POSTGRES_URL=postgres://...

# Admin secret for protected endpoints (required)
ADMIN_SECRET=your-secure-admin-secret

# Secret used to sign admin session cookies — must be a random 32-byte hex string.
# Generate with: openssl rand -hex 32
# Keep this separate from ADMIN_SECRET.
ADMIN_SESSION_SECRET=your-session-signing-secret

# Public URL of this web app
NEXT_PUBLIC_APP_URL=https://your-web-app.vercel.app

# Public URL of the separate MCP app (shown in MCP info page and used by the /demo chatbot server-side)
NEXT_PUBLIC_MCP_URL=https://your-mcp-app.vercel.app

# Server-side URL of the MCP app used by the /demo chatbot (overrides NEXT_PUBLIC_MCP_URL if set,
# useful for local dev where the MCP app runs on a different port)
MCP_URL=http://localhost:3001

# Cron secret - Vercel injects this automatically
CRON_SECRET=
