# OpenRouter API key (required)
OPENROUTER_API_KEY=sk-or-...

# Vercel Postgres connection string (required)
POSTGRES_URL=postgres://...

# Admin secret for protected endpoints (required)
ADMIN_SECRET=your-secure-admin-secret

# MCP API key - if set, MCP endpoint requires Bearer auth (optional)
MCP_API_KEY=

# Cron secret - Vercel injects this automatically (optional)
CRON_SECRET=
