# ─────────────────────────────────────────────
# OpenRouter MCP Registry — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local (for local dev) or configure in Vercel dashboard

# ── Required ──────────────────────────────────

# OpenRouter API key used to fetch the model catalog
OPENROUTER_API_KEY=sk-or-v1-...

# Vercel Postgres connection string
# Get from: Vercel Dashboard → Storage → Postgres → .env.local tab
POSTGRES_URL=postgres://default:password@host:5432/verceldb

# Secret token required for admin endpoints:
#   POST /api/admin/refresh
#   GET  /api/admin/sync-status
# Use a long random string: openssl rand -hex 32
ADMIN_SECRET=change-me-to-a-long-random-string

# ── Optional ──────────────────────────────────

# If set, the MCP endpoint (/api/mcp) requires this token as Bearer auth.
# Leave empty to keep the MCP endpoint open.
MCP_API_KEY=

# Vercel automatically injects CRON_SECRET for cron jobs.
# You only need this if running cron locally.
CRON_SECRET=

# Public URL of the deployed app (used in MCP Info page and metadata)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
